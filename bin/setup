#!/bin/bash

set -e

mitamae_version="2.0.0"
mitamae_linux_sha256="e63821869c787c85c43ae0ebb7e5dec2c1bc00d4ea8efce272d646080e6baa97"
mitamae_darwin_sha256="090c6a4499235d79191632188c70846de93a7e2c77f9077ef61b530149209218"

mitamae_cache="mitamae-${mitamae_version}"
if ! [ -f "bin/${mitamae_cache}" ]; then
  case "$(uname)" in
    "Linux")
      mitamae_bin="mitamae-x86_64-linux"
      mitamae_sha256="$mitamae_linux_sha256"
      ;;
    "Darwin")
      mitamae_bin="mitamae-aarch64-darwin"
      mitamae_sha256="$mitamae_darwin_sha256"
      ;;
    *)
      echo "unexpected uname: $(uname)"
      exit 1
      ;;
  esac

  curl -o "bin/${mitamae_bin}" -fL "https://github.com/itamae-kitchen/mitamae/releases/download/v${mitamae_version}/${mitamae_bin}"
  sha256="$(openssl dgst -sha256 "bin/${mitamae_bin}" | cut -d" " -f2)"
  if [ "$mitamae_sha256" != "$sha256" ]; then
    echo "checksum verification failed!\nexpected: ${mitamae_sha256}\n  actual: ${sha256}"
    exit 1
  fi

  mv "bin/${mitamae_bin}" "bin/${mitamae_cache}"
  chmod +x "bin/${mitamae_cache}"
fi
ln -sf "${mitamae_cache}" bin/mitamae
